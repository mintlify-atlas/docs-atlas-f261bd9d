  "keyFeatures": [
    "Modal editing with Vim-inspired modes (normal, insert, visual, etc.)",
    "Complete keyboard-driven navigation with customizable keymaps",
    "Hints system for label-based element selection",
    "TypeScript-based configuration with full type safety",
    "Extensive ex command system (67+ built-in commands)",
    "Autocmds for event-driven automation",
    "Web Extensions API support",
    "Custom CSS injection for browser UI customization",
    "Process spawning and file system access from config",
    "Buffer-local settings for per-tab configuration",
    "Jumplist navigation history",
    "Which-key contextual keybinding hints",
    "Custom mode registration",
    "Fuzzy tab search",
    "Search engine management"
  ],
  "publicApiSurface": [
    "glide.ctx - Context information (mode, version, url, os)",
    "glide.o - Global options (mapping_timeout, hint_size, etc.)",
    "glide.bo - Buffer-specific options",
    "glide.g - Global variables (mapleader, etc.)",
    "glide.keymaps - Keymap management (set, del, list)",
    "glide.buf - Buffer-scoped APIs",
    "glide.autocmds - Event handlers (create, remove)",
    "glide.hints - Hints system (show, label_generators)",
    "glide.tabs - Tab management (active, query, unload)",
    "glide.commandline - Command line UI (show, close, is_active)",
    "glide.excmds - Ex commands (execute, create)",
    "glide.findbar - Native find bar (open, next_match, close)",
    "glide.content - Content process execution (fn, execute)",
    "glide.keys - Key event handling (send, next, parse)",
    "glide.addons - Extension management (install, list)",
    "glide.search_engines - Search engine management (add)",
    "glide.styles - Custom CSS (add, remove, has, get)",
    "glide.prefs - Firefox preferences (set, get, clear, scoped)",
    "glide.env - Environment variables (get, set, delete)",
    "glide.process - Process spawning (spawn, execute)",
    "glide.path - Path utilities (cwd, home_dir, join)",
    "glide.fs - File system (read, write, exists, stat, mkdir)",
    "glide.messengers - Inter-process communication (create)",
    "glide.modes - Mode registration (register, list)",
    "glide.include - Config file inclusion",
    "glide.unstable - Experimental APIs (split_views)",
    "browser.* - Web Extensions API (tabs, scripting, runtime, etc.)",
    "Ex Commands: tab, config_reload, hint, scroll_*, go_*, mode_change, etc."
  ]
}
